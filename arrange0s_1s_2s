func sortList(head *ListNode) *ListNode {
	count := make([]int,3)

	// count 0s, 1s and 2s in the linked list
	curr := head
	for curr != nil {
		count[curr.Val]++
		curr= curr.Next
	}

	i:=0
	curr = head
	// update the linked list with sorted order
	for curr !=nil{
    if count[i] == 0 {
		i++
	} else {
		curr.Val = i
		count[i]--
		curr = curr.Next			
	}
}
return head
}

