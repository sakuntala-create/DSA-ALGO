func isPalindrome(head *ListNode) bool {
	if head == nil || head.Next == nil {
		return true
	}

	// Step 1: Find the middle of the linked list
   slow, fast := head, head
   for fast !=nil && fast.Next != nil{
	 slow = slow.Next
	 fast = fast.Next.Next
   }

  secordHalf := reverseList(slow)
  firstHalf := head

  // Step 2: Compare the first half and the reversed second half
  for secordHalf != nil {
	if firstHalf.Val != secordHalf.Val {
		return false
	}
	firstHalf = firstHalf.Next
	secordHalf = secordHalf.Next
  }
  return true
}

func reverseList(head *ListNode) *ListNode {
	var prev *ListNode
	current := head

	for current != nil {
		next :=  current.Next
		current.Next = prev
		prev = current
		current = next
	}
	return prev
}

