
type ListNode struct{
	Val int
	Next *ListNode
}

// merge alternatively two linked list
func mergeAlternately(l1 *ListNode, l2 *ListNode) *ListNode {
	curr1:= l1
	curr2:= l2

	for curr1 != nil && curr2 != nil {
		next1:= curr1.Next
		next2:= curr2.Next

		curr1.Next= curr2
		curr2.Next = next1
		curr1= next1
		curr2= next2

	}

	return l1,curr2
}
